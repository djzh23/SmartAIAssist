@page "/tools"
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Tools — SmartAssist</PageTitle>

<div class="tools-page">
    <h1 class="tools-heading">Available Tools</h1>
    <p class="tools-subheading">Click any card to learn more and try it in chat.</p>

    <div class="tools-grid">
        @foreach (var tool in tools)
        {
            <div class="tool-card @(tool.IsFeatured ? "featured" : "")"
                 @onclick="() => OpenModal(tool)">
                <div class="tool-icon-circle" style="background: @tool.IconBg">
                    <span class="tool-emoji">@tool.Icon</span>
                </div>
                <div class="tool-name-row">
                    <div class="tool-name">@tool.Name</div>
                    @if (tool.IsFeatured) { <span class="tool-badge-featured">FEATURED</span> }
                </div>
                <p class="tool-description">@tool.ShortDescription</p>
                <div class="tool-try-hint">Click to learn more →</div>
            </div>
        }
    </div>
</div>

@if (selectedTool is not null)
{
    <div class="modal-backdrop" @onclick="CloseModal" @onkeydown="HandleModalKey" tabindex="-1">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-icon">
                <div class="modal-icon-circle" style="background: @selectedTool.IconBg">
                    <span class="modal-emoji">@selectedTool.Icon</span>
                </div>
            </div>
            <h2 class="modal-title">@selectedTool.Name</h2>
            <p class="modal-description">@selectedTool.FullDescription</p>

            <div class="modal-examples">
                <div class="modal-examples-label">Example prompts</div>
                @foreach (var example in selectedTool.Examples)
                {
                    <div class="modal-example-item">💬 @example</div>
                }
            </div>

            <div class="modal-buttons">
                <button class="modal-btn-primary" @onclick="() => TryInChat(selectedTool.ChatParam)">
                    Try in Chat
                </button>
                <button class="modal-btn-ghost" @onclick="CloseModal">
                    Close
                </button>
            </div>
        </div>
    </div>
}

@code {
    private ToolInfo? selectedTool;

    private record ToolInfo(
        string Id,
        string Name,
        string ShortDescription,
        string FullDescription,
        string[] Examples,
        string Icon,
        string IconBg,
        string ChatParam,
        bool IsFeatured = false
    );

    private readonly List<ToolInfo> tools =
    [
        new("weather", "Weather Assistant",
            "Get real-time weather for any city",
            "Ask about weather in any city worldwide. The AI uses live weather data to give you current conditions, temperature, and helpful tips.",
            ["Wie ist das Wetter in Berlin?", "What is the weather in Tokyo?", "Is it raining in London today?"],
            "🌤️", "#E8F4FD", "weather"),

        new("summary", "Text Summarizer",
            "Summarize any long text instantly",
            "Paste any long text and get a concise summary. Perfect for articles, emails, or documents you need to understand quickly.",
            ["Fasse diesen Text zusammen: [your text here]", "Summarize this article in 3 bullet points: [text]"],
            "📝", "#FFF3E0", "summary"),

        new("jokes", "Joke Generator",
            "Get a random joke to brighten your day",
            "Need a laugh? Ask for a random joke anytime. The AI fetches fresh jokes and delivers them with perfect timing.",
            ["Erzähl mir einen Witz", "Tell me a programming joke", "Give me a funny joke about dogs"],
            "😄", "#F3E8FF", "jokes"),

        new("language", "Language Learning Mode",
            "Chat and learn a new language simultaneously",
            "Activate a target language and start chatting in your native language. The AI translates your messages and responds in your target language — perfect for learners.",
            ["Activate Spanish mode, then write: Hallo wie geht es dir?", "Guten Morgen — practice Spanish every day"],
            "🌍", "#E8FEF0", "language", IsFeatured: true),
    ];

    private void OpenModal(ToolInfo tool)
    {
        selectedTool = tool;
        JS.InvokeVoidAsync("eval", "setTimeout(()=>document.querySelector('.modal-backdrop')?.focus(),50)");
    }

    private void CloseModal() => selectedTool = null;

    private void TryInChat(string param) => Nav.NavigateTo($"/chat?tool={param}");

    private void HandleModalKey(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") CloseModal();
    }
}

<style>
    .tools-page {
        max-width: 800px;
        padding: var(--space-xl);
    }

    .tools-heading {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--color-text);
        margin-bottom: var(--space-xs);
    }

    .tools-subheading {
        color: var(--color-text-muted);
        margin-bottom: var(--space-xl);
        font-size: 0.9rem;
    }

    .tools-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-md);
    }

    .tool-card {
        background: var(--color-bg);
        border: 1.5px solid #e5e7eb;
        border-radius: var(--radius-md);
        padding: var(--space-lg);
        cursor: pointer;
        transition: box-shadow 0.15s, border-color 0.15s, transform 0.1s;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .tool-card:hover {
        box-shadow: var(--shadow-md);
        border-color: var(--color-primary);
        transform: translateY(-2px);
    }

    .tool-card.featured {
        border-color: var(--color-primary);
        background: var(--color-primary-light);
    }

    .tool-icon-circle {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .tool-emoji {
        font-size: 1.5rem;
        line-height: 1;
    }

    .tool-name-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .tool-name {
        font-weight: 600;
        font-size: 1rem;
        color: var(--color-text);
    }

    .tool-badge-featured {
        display: inline-block;
        background: var(--color-primary);
        color: white;
        font-size: 9px;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: var(--radius-pill);
        letter-spacing: 0.06em;
        flex-shrink: 0;
    }

    .tool-description {
        font-size: 0.875rem;
        color: var(--color-text-muted);
        margin: 0;
        line-height: 1.5;
    }

    .tool-try-hint {
        font-size: 0.8rem;
        color: var(--color-primary);
        margin-top: auto;
        padding-top: var(--space-xs);
        font-weight: 500;
    }

    /* ── Modal ─────────────────────────────────────────── */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        padding: var(--space-md);
        animation: fadeIn 0.18s ease;
        outline: none;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
    }

    .modal-box {
        background: var(--color-bg);
        border-radius: 16px;
        max-width: 480px;
        width: 100%;
        padding: var(--space-xl);
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        animation: slideUp 0.18s ease;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .modal-icon {
        display: flex;
        justify-content: center;
    }

    .modal-icon-circle {
        width: 64px;
        height: 64px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-emoji {
        font-size: 2rem;
        line-height: 1;
    }

    .modal-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-text);
        text-align: center;
        margin: 0;
    }

    .modal-description {
        color: var(--color-text-muted);
        font-size: 0.9rem;
        line-height: 1.6;
        margin: 0;
        text-align: center;
    }

    .modal-examples {
        background: var(--color-bg-secondary);
        border-radius: var(--radius-md);
        padding: var(--space-md);
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .modal-examples-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 4px;
    }

    .modal-example-item {
        font-size: 0.85rem;
        color: var(--color-text);
        padding: 6px 10px;
        background: var(--color-bg);
        border-radius: var(--radius-sm);
        border: 1px solid #e5e7eb;
        line-height: 1.4;
    }

    .modal-buttons {
        display: flex;
        gap: var(--space-sm);
        margin-top: var(--space-xs);
    }

    .modal-btn-primary {
        flex: 1;
        background: var(--color-primary);
        color: white;
        border: none;
        border-radius: var(--radius-sm);
        padding: 11px 20px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s;
    }

    .modal-btn-primary:hover {
        background: var(--color-primary-hover);
    }

    .modal-btn-ghost {
        flex: 1;
        background: none;
        color: var(--color-text-muted);
        border: 1.5px solid #e5e7eb;
        border-radius: var(--radius-sm);
        padding: 11px 20px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
    }

    .modal-btn-ghost:hover {
        border-color: var(--color-text-muted);
        color: var(--color-text);
    }

    @@media (max-width: 768px) {
        .tools-grid {
            grid-template-columns: 1fr;
        }

        .modal-box {
            padding: var(--space-lg);
        }
    }
</style>
