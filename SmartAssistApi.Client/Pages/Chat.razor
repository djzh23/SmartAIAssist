@page "/chat"
@inject AgentApiService AgentApi
@inject IJSRuntime JS
@using SmartAssistApi.Client.Models

<div class="chat-layout">

    <!-- Hamburger (mobile) -->
    <button class="hamburger-btn" @onclick="ToggleSidebar" aria-label="Toggle sidebar">&#9776;</button>

    <!-- Zone 1 — Session sidebar -->
    <aside class="chat-sidebar @(sidebarOpen ? "sidebar-open" : "")">

        <button class="new-chat-btn" @onclick="NewSession">
            <span class="new-chat-plus">+</span>
            New Chat
        </button>

        <!-- Language Learning Panel -->
        <div class="ll-panel">
            <label class="ll-toggle-row">
                <span class="ll-toggle-label">🌍 Language Learning</span>
                <input type="checkbox" class="ll-toggle" @bind="languageLearningMode" />
            </label>
            @if (languageLearningMode)
            {
                <div class="ll-options">
                    <span class="ll-label">I speak:</span>
                    <select class="ll-select" @bind="nativeLanguageCode">
                        <option value="de">German</option>
                        <option value="en">English</option>
                        <option value="fr">French</option>
                        <option value="ar">Arabic</option>
                    </select>
                    <span class="ll-label">I want to learn:</span>
                    <select class="ll-select" @bind="targetLanguageCode">
                        <option value="es">Spanish</option>
                        <option value="fr">French</option>
                        <option value="en">English</option>
                        <option value="it">Italian</option>
                        <option value="de">German</option>
                        <option value="ar">Arabic</option>
                        <option value="pt">Portuguese</option>
                    </select>
                    <p class="ll-info">The AI responds in your target language with native-language support.</p>
                </div>
            }
        </div>

        <!-- Session list -->
        @if (sessions.Count == 0)
        {
            <div class="sessions-empty">
                <span>No conversations yet</span>
            </div>
        }
        else
        {
            <ul class="session-list">
                @foreach (var id in sessions.Keys)
                {
                    var preview = sessions[id].FirstOrDefault(m => m.IsUser)?.Text ?? "New conversation";
                    var lastTime = sessions[id].LastOrDefault()?.Timestamp.ToLocalTime().ToString("HH:mm") ?? "";
                    <li class="session-item @(id == activeSessionId ? "active" : "")"
                        @onclick="() => SwitchSession(id)">
                        <span class="session-preview">@(preview.Length > 38 ? preview[..38] + "…" : preview)</span>
                        <span class="session-time">@lastTime</span>
                    </li>
                }
            </ul>
        }
    </aside>

    <!-- Zone 2 + 3 — Main chat -->
    <main class="chat-main">
        <div class="chat-content-wrapper">

            @if (languageLearningMode)
            {
                <div class="ll-mode-header">
                    <span class="ll-mode-badge">🌍 Learning: @targetLanguageName</span>
                </div>
            }

            <div class="message-list">
                @if (ActiveMessages.Count == 0)
                {
                    <div class="empty-state">
                        <div class="empty-icon">💬</div>
                        <div class="empty-title">Start a new conversation</div>
                        <div class="empty-subtitle">Type a message below or click "+ New Chat"</div>
                    </div>
                }
                else
                {
                    @foreach (var msg in ActiveMessages)
                    {
                        <div class="message-bubble @(msg.IsUser ? "user" : "assistant")">
                            @if (!msg.IsUser && languageLearningMode)
                            {
                                var parsed = ParseAssistantMessage(msg.Text);
                                <div class="bubble-text ll-bubble">
                                    @if (parsed.Translation is not null)
                                    {
                                        <div class="ll-translation">@parsed.Translation</div>
                                    }

                                    <div class="ll-pair-grid">
                                        @if (parsed.TargetLanguageText is not null)
                                        {
                                            <div class="ll-card ll-card-tl">
                                                <div class="ll-card-title ll-card-title-with-action">
                                                    <span>TL</span>
                                                    <button class="ll-audio-icon-btn"
                                                            @onclick="() => SpeakText(parsed.TargetLanguageAudio ?? parsed.TargetLanguageText, targetLanguageCode)"
                                                            type="button"
                                                            aria-label="Play target language audio"
                                                            title="Play audio">
                                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                                            <path d="M14 5v14l-5-4H5a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1h4l5-4z"></path>
                                                            <path d="M17.5 8.5a4.5 4.5 0 0 1 0 7"></path>
                                                            <path d="M19.8 6a8 8 0 0 1 0 12"></path>
                                                        </svg>
                                                    </button>
                                                </div>
                                                <div class="ll-card-body">@parsed.TargetLanguageText</div>
                                            </div>
                                        }
                                        @if (parsed.NativeLanguageText is not null)
                                        {
                                            <div class="ll-card ll-card-nl">
                                                <div class="ll-card-title">NL</div>
                                                <div class="ll-card-body">@parsed.NativeLanguageText</div>
                                            </div>
                                        }
                                    </div>

                                    @if (parsed.Grammar is not null)
                                    {
                                        <div class="ll-card ll-card-grammar">
                                            <div class="ll-card-title">Grammar</div>
                                            <div class="ll-card-body">@parsed.Grammar</div>
                                        </div>
                                    }

                                    @if (parsed.Vocabulary is not null)
                                    {
                                        <div class="ll-card ll-card-vocab">
                                            <div class="ll-card-title">Vocabulary</div>
                                            <div class="ll-card-body">@parsed.Vocabulary</div>
                                        </div>
                                    }

                                    @if (parsed.MiniExercise is not null)
                                    {
                                        <div class="ll-card ll-card-exercise">
                                            <div class="ll-card-title">Mini Exercise</div>
                                            <div class="ll-card-body">@parsed.MiniExercise</div>
                                        </div>
                                    }

                                    @if (parsed.Hint is not null)
                                    {
                                        <div class="ll-card ll-card-hint">
                                            <div class="ll-card-title">Hint</div>
                                            <div class="ll-card-body">@parsed.Hint</div>
                                        </div>
                                    }

                                    @if (parsed.Tip is not null)
                                    {
                                        <div class="ll-card ll-card-tip">
                                            <div class="ll-card-title">Tip</div>
                                            <div class="ll-card-body">@parsed.Tip</div>
                                        </div>
                                    }

                                    @if (parsed.FollowUpQuestion is not null)
                                    {
                                        <div class="ll-card ll-card-followup">
                                            <div class="ll-card-title">Follow-up</div>
                                            <div class="ll-card-body">@parsed.FollowUpQuestion</div>
                                        </div>
                                    }

                                    @if (parsed.Pronunciation is not null)
                                    {
                                        <div class="ll-card ll-card-pronunciation">
                                            <div class="ll-card-title">Pronunciation</div>
                                            <div class="ll-card-body">@parsed.Pronunciation</div>
                                        </div>
                                    }

                                    @if (parsed.MainText is not null)
                                    {
                                        <div class="ll-card ll-card-main">
                                            <div class="ll-card-title">Notes</div>
                                            <div class="ll-card-body">@parsed.MainText</div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="bubble-text">@msg.Text</div>
                            }
                            @if (msg.ToolUsed is not null)
                            {
                                <span class="tool-pill">⚙ @msg.ToolUsed</span>
                            }
                            <div class="bubble-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</div>
                        </div>
                    }
                    @if (isLoading)
                    {
                        <div class="message-bubble assistant">
                            <div class="bubble-text typing-indicator">
                                <span></span><span></span><span></span>
                            </div>
                        </div>
                    }
                }
            </div>

            @if (errorMessage is not null)
            {
                <div class="chat-error-banner">
                    <span>@errorMessage</span>
                    <button class="error-dismiss" @onclick="() => errorMessage = null">✕</button>
                </div>
            }

            <!-- Zone 3 — Input area -->
            <div class="chat-input-area">
                <div class="chat-input-box @(isInputFocused ? "focused" : "")">
                    <textarea class="chat-textarea"
                              @bind="inputText"
                              @bind:event="oninput"
                              @onkeydown="HandleKeyDown"
                              @onfocus="() => isInputFocused = true"
                              @onblur="() => isInputFocused = false"
                              placeholder="Type a message…"
                              maxlength="500"
                              rows="2"
                              disabled="@isLoading" />
                    <div class="input-footer">
                        <span class="input-hint">Enter to send · Shift+Enter for newline</span>
                        <span class="char-counter @(inputText.Length > 450 ? "near-limit" : "")">
                            @inputText.Length / 500
                        </span>
                    </div>
                </div>
                <button class="send-btn"
                        @onclick="SendMessage"
                        disabled="@(isLoading || string.IsNullOrWhiteSpace(inputText))">
                    @if (isLoading)
                    {
                        <span class="send-spinner"></span>
                    }
                    else
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                        </svg>
                    }
                </button>
            </div>

        </div><!-- end chat-content-wrapper -->
    </main>
</div>

@code {
    private Dictionary<string, List<ChatMessage>> sessions = new();
    private string? activeSessionId;
    private string inputText = "";
    private bool isLoading;
    private string? errorMessage;
    private bool sidebarOpen;
    private bool isInputFocused;

    // Language learning state
    private bool languageLearningMode;
    private string nativeLanguageCode = "de";
    private string targetLanguageCode = "es";
    private const string DefaultLearningLevel = "A1";
    private const string DefaultLearningGoal = "speaking basics, verbs, sentence structure";

    private static readonly Dictionary<string, string> LanguageNames = new()
    {
        ["de"] = "German",  ["en"] = "English", ["es"] = "Spanish",
        ["fr"] = "French",  ["it"] = "Italian", ["ar"] = "Arabic",
        ["pt"] = "Portuguese"
    };

    private string nativeLanguageName => LanguageNames.GetValueOrDefault(nativeLanguageCode, nativeLanguageCode);
    private string targetLanguageName => LanguageNames.GetValueOrDefault(targetLanguageCode, targetLanguageCode);

    private List<ChatMessage> ActiveMessages =>
        activeSessionId is not null && sessions.TryGetValue(activeSessionId, out var msgs)
            ? msgs
            : new List<ChatMessage>();

    private sealed class ParsedLearningMessage
    {
        public string? Translation { get; init; }
        public string? TargetLanguageText { get; init; }
        public string? TargetLanguageAudio { get; init; }
        public string? NativeLanguageText { get; init; }
        public string? Grammar { get; init; }
        public string? Vocabulary { get; init; }
        public string? MiniExercise { get; init; }
        public string? Hint { get; init; }
        public string? Tip { get; init; }
        public string? FollowUpQuestion { get; init; }
        public string? Pronunciation { get; init; }
        public string? MainText { get; init; }
    }

    private static ParsedLearningMessage ParseAssistantMessage(string text)
    {
        var lines = text.Split('\n');
        string? translation = null;
        var sections = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);
        var mainLines = new List<string>();
        string? currentSection = null;

        foreach (var rawLine in lines)
        {
            var trimmed = CleanMarkdown(rawLine.Trim());
            if (string.IsNullOrWhiteSpace(trimmed) || IsDivider(trimmed))
                continue;

            if (translation is null && trimmed.StartsWith("(") && trimmed.EndsWith(")"))
            {
                translation = trimmed;
                continue;
            }

            if (TryGetSection(trimmed, out var sectionKey, out var inlineContent))
            {
                currentSection = sectionKey;
                if (!string.IsNullOrWhiteSpace(inlineContent))
                    AddSectionLine(sections, sectionKey, inlineContent);
            }
            else if (currentSection is not null)
            {
                AddSectionLine(sections, currentSection, trimmed);
            }
            else
            {
                mainLines.Add(trimmed);
            }
        }

        return new ParsedLearningMessage
        {
            Translation = translation,
            TargetLanguageText = JoinSection(sections, "TL"),
            TargetLanguageAudio = JoinSection(sections, "TL_AUDIO"),
            NativeLanguageText = JoinSection(sections, "NL"),
            Grammar = JoinSection(sections, "Grammar"),
            Vocabulary = JoinSection(sections, "Vocabulary"),
            MiniExercise = JoinSection(sections, "Mini Exercise"),
            Hint = JoinSection(sections, "Hint"),
            Tip = JoinSection(sections, "Tip"),
            FollowUpQuestion = JoinSection(sections, "Follow-up question"),
            Pronunciation = JoinSection(sections, "Pronunciation"),
            MainText = mainLines.Count > 0 ? string.Join("\n", mainLines).Trim() : null
        };
    }

    private static void AddSectionLine(Dictionary<string, List<string>> sections, string key, string value)
    {
        if (!sections.TryGetValue(key, out var lines))
        {
            lines = new List<string>();
            sections[key] = lines;
        }

        lines.Add(value);
    }

    private static string? JoinSection(Dictionary<string, List<string>> sections, string key)
    {
        return sections.TryGetValue(key, out var lines) && lines.Count > 0
            ? string.Join("\n", lines).Trim()
            : null;
    }

    private static bool IsDivider(string line)
    {
        return line == "---" || line == "___";
    }

    private static string CleanMarkdown(string line)
    {
        return line.Replace("**", string.Empty).Trim();
    }

    private static bool TryGetSection(string line, out string sectionKey, out string inlineContent)
    {
        inlineContent = string.Empty;

        if (TryMatchSection(line, "TL_AUDIO", out inlineContent) || TryMatchSection(line, "TL AUDIO", out inlineContent))
        {
            sectionKey = "TL_AUDIO";
            return true;
        }

        if (TryMatchSection(line, "TL", out inlineContent))
        {
            sectionKey = "TL";
            return true;
        }

        if (TryMatchSection(line, "NL", out inlineContent))
        {
            sectionKey = "NL";
            return true;
        }

        if (TryMatchSection(line, "Grammar (NL)", out inlineContent) || TryMatchSection(line, "Grammar", out inlineContent))
        {
            sectionKey = "Grammar";
            return true;
        }

        if (TryMatchSection(line, "Vocabulary", out inlineContent))
        {
            sectionKey = "Vocabulary";
            return true;
        }

        if (TryMatchSection(line, "Mini Exercise", out inlineContent))
        {
            sectionKey = "Mini Exercise";
            return true;
        }

        if (TryMatchSection(line, "Hint (NL)", out inlineContent) || TryMatchSection(line, "Hint", out inlineContent))
        {
            sectionKey = "Hint";
            return true;
        }

        if (TryMatchSection(line, "Tip", out inlineContent) || line.StartsWith("💡", StringComparison.Ordinal))
        {
            sectionKey = "Tip";
            inlineContent = line.StartsWith("💡", StringComparison.Ordinal) ? line[1..].Trim() : inlineContent;
            return true;
        }

        if (TryMatchSection(line, "Follow-up question", out inlineContent) || TryMatchSection(line, "Follow up question", out inlineContent))
        {
            sectionKey = "Follow-up question";
            return true;
        }

        if (TryMatchSection(line, "Pronunciation", out inlineContent))
        {
            sectionKey = "Pronunciation";
            return true;
        }

        sectionKey = string.Empty;
        return false;
    }

    private static bool TryMatchSection(string line, string label, out string inlineContent)
    {
        inlineContent = string.Empty;
        if (!line.StartsWith(label, StringComparison.OrdinalIgnoreCase))
            return false;

        var remainder = line[label.Length..].TrimStart();
        if (remainder.StartsWith(":", StringComparison.Ordinal))
            remainder = remainder[1..].Trim();

        inlineContent = remainder;
        return true;
    }

    private async Task SpeakText(string? text, string languageCode)
    {
        if (string.IsNullOrWhiteSpace(text))
            return;

        try
        {
            var audio = await AgentApi.GenerateSpeechAsync(text, languageCode);
            if (audio is { Length: > 0 })
            {
                var base64 = Convert.ToBase64String(audio);
                var audioUrl = $"data:audio/mpeg;base64,{base64}";
                var escapedAudioUrl = System.Text.Json.JsonSerializer.Serialize(audioUrl);
                await JS.InvokeVoidAsync("eval",
                    "window.__smartAssistPlayer?.pause?.(); " +
                    "window.__smartAssistPlayer = new Audio(" + escapedAudioUrl + "); " +
                    "window.__smartAssistPlayer.play();");
                errorMessage = null;
            }
            else
            {
                errorMessage = "Audio generation returned an empty result.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Audio unavailable: {ex.Message}";
        }
    }

    private void NewSession()
    {
        var id = Guid.NewGuid().ToString()[..8];
        sessions[id] = new List<ChatMessage>();
        activeSessionId = id;
        errorMessage = null;
    }

    private void SwitchSession(string id)
    {
        activeSessionId = id;
        errorMessage = null;
        sidebarOpen = false;
    }

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private async Task SendMessage()
    {
        var text = inputText.Trim();
        if (string.IsNullOrWhiteSpace(text) || isLoading) return;
        if (text.Length > 500)
        {
            errorMessage = "Message must not exceed 500 characters.";
            return;
        }

        if (activeSessionId is null) NewSession();

        sessions[activeSessionId!].Add(new ChatMessage { Text = text, IsUser = true });
        inputText = "";
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await AgentApi.AskAsync(
                text,
                activeSessionId,
                languageLearningMode,
                languageLearningMode ? targetLanguageName : null,
                languageLearningMode ? nativeLanguageName : null,
                languageLearningMode ? targetLanguageCode : null,
                languageLearningMode ? nativeLanguageCode : null,
                languageLearningMode ? DefaultLearningLevel : null,
                languageLearningMode ? DefaultLearningGoal : null
            );
            sessions[activeSessionId!].Add(new ChatMessage
            {
                Text = response.Reply,
                ToolUsed = response.ToolUsed,
                IsUser = false
            });
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            await ScrollToBottom();
        }
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(50);
        await JS.InvokeVoidAsync("eval",
            "var el = document.querySelector('.message-list'); if (el) el.scrollTop = el.scrollHeight;");
    }
}



