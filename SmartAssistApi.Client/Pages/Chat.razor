@page "/chat"
@inject AgentApiService AgentApi
@inject IJSRuntime JS
@inject NavigationManager Nav
@using SmartAssistApi.Client.Models

<div class="chat-layout">

    <!-- Hamburger (mobile) -->
    <button class="hamburger-btn" @onclick="ToggleSidebar" aria-label="Toggle sidebar">&#9776;</button>

    <!-- Zone 1 — Session sidebar -->
    <aside class="chat-sidebar @(sidebarOpen ? "sidebar-open" : "")">

        <button class="new-chat-btn" @onclick="NewSession">
            <span class="new-chat-plus">+</span>
            New Chat
        </button>

        <!-- Language Learning Panel -->
        <div class="ll-panel">
            <label class="ll-toggle-row" title="@(languageLearningLocked ? "Language mode is active for this session" : "")">
                <span class="ll-toggle-label">🌍 Language Learning</span>
                <input type="checkbox" class="ll-toggle" @bind="languageLearningMode" disabled="@languageLearningLocked" />
            </label>
            @if (languageLearningMode)
            {
                <div class="ll-options">
                    <span class="ll-label">I speak:</span>
                    <select class="ll-select" @bind="nativeLanguageCode">
                        <option value="de">German</option>
                        <option value="en">English</option>
                        <option value="fr">French</option>
                        <option value="ar">Arabic</option>
                    </select>
                    <span class="ll-label">I want to learn:</span>
                    <select class="ll-select" @bind="targetLanguageCode">
                        <option value="es">Spanish</option>
                        <option value="fr">French</option>
                        <option value="en">English</option>
                        <option value="it">Italian</option>
                        <option value="de">German</option>
                        <option value="ar">Arabic</option>
                        <option value="pt">Portuguese</option>
                    </select>
                    <p class="ll-info">The AI responds in your target language with native-language support.</p>
                </div>
            }
        </div>

        <!-- Session list (filtered by current tool type) -->
        @{
            var visibleSessions = sessionOrder
                .Where(id => sessions.ContainsKey(id) &&
                             sessionToolTypes.GetValueOrDefault(id, "general") == currentToolType)
                .ToList();
        }
        @if (visibleSessions.Count == 0)
        {
            <div class="sessions-empty">
                <span>No conversations yet</span>
            </div>
        }
        else
        {
            <ul class="session-list">
                @foreach (var id in visibleSessions)
                {
                    var badge = GetToolBadge(currentToolType);
                    var preview = sessions[id].FirstOrDefault(m => m.IsUser)?.Text ?? "New conversation";
                    var lastTime = sessions[id].LastOrDefault()?.Timestamp.ToLocalTime().ToString("HH:mm") ?? "";
                    <li class="session-item @(id == activeSessionId ? "active" : "")"
                        @onclick="() => SwitchSession(id)">
                        <span class="session-preview">
                            @if (badge is not null)
                            {
                                <span class="session-tool-badge">@badge</span>
                            }
                            @(preview.Length > 34 ? preview[..34] + "…" : preview)
                        </span>
                        <span class="session-time">@lastTime</span>
                    </li>
                }
            </ul>

            <button class="clear-history-btn" @onclick="ClearHistory">Clear history</button>
        }
    </aside>

    <!-- Zone 2 + 3 — Main chat -->
    <main class="chat-main">
        <div class="chat-content-wrapper">

            @if (languageLearningMode)
            {
                <div class="ll-mode-header">
                    <span class="ll-mode-badge">🌍 Learning: @targetLanguageName</span>
                </div>
            }

            <div class="message-list">
                @if (ActiveMessages.Count == 0)
                {
                    <div class="empty-state">
                        <div class="empty-icon">💬</div>
                        <div class="empty-title">Start a new conversation</div>
                        <div class="empty-subtitle">Type a message below or click "+ New Chat"</div>
                    </div>
                }
                else
                {
                    @foreach (var msg in ActiveMessages)
                    {
                        @if (!msg.IsUser && msg.LearningData is not null)
                        {
                            <!-- Structured language learning response: 3 boxes -->
                            <div class="learning-response">
                                <div class="learning-box learning-box-target">
                                    <div class="learning-box-header">
                                        <span>🌍 @targetLanguageName</span>
                                        <button class="speak-btn"
                                                type="button"
                                                title="Speak"
                                                @onclick="() => SpeakTextBrowser(msg.LearningData.TargetLanguageText, targetLanguageCode)">
                                            🔊
                                        </button>
                                    </div>
                                    <div class="learning-box-text">@msg.LearningData.TargetLanguageText</div>
                                </div>
                                <div class="learning-box learning-box-native">
                                    <div class="learning-box-header">
                                        <span>🗣️ @nativeLanguageName</span>
                                    </div>
                                    <div class="learning-box-text">@msg.LearningData.NativeLanguageText</div>
                                </div>
                                @if (msg.LearningData.LearnTip is not null)
                                {
                                    <div class="learning-box learning-box-tip">
                                        <div class="learning-box-header">
                                            <span>💡 Learn</span>
                                        </div>
                                        <div class="learning-box-text">@msg.LearningData.LearnTip</div>
                                    </div>
                                }
                                <div class="learning-timestamp">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</div>
                            </div>
                        }
                        else
                        {
                            <div class="message-bubble @(msg.IsUser ? "user" : "assistant")">
                                <div class="bubble-text">@msg.Text</div>
                                @if (msg.ToolUsed is not null)
                                {
                                    <span class="tool-pill">⚙ @msg.ToolUsed</span>
                                }
                                <div class="bubble-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</div>
                            </div>
                        }
                    }
                    @if (isLoading)
                    {
                        <div class="message-bubble assistant">
                            <div class="bubble-text typing-indicator">
                                <span></span><span></span><span></span>
                            </div>
                        </div>
                    }
                }
            </div>

            @if (errorMessage is not null)
            {
                <div class="chat-error-banner">
                    <span>@errorMessage</span>
                    <button class="error-dismiss" @onclick="() => errorMessage = null">✕</button>
                </div>
            }

            <!-- Zone 3 — Input area -->
            <div class="chat-input-area">
                <div class="chat-input-box @(isInputFocused ? "focused" : "")">
                    <textarea class="chat-textarea"
                              @bind="inputText"
                              @bind:event="oninput"
                              @onkeydown="HandleKeyDown"
                              @onfocus="() => isInputFocused = true"
                              @onblur="() => isInputFocused = false"
                              placeholder="Type a message…"
                              maxlength="500"
                              rows="2"
                              disabled="@isLoading" />
                    <div class="input-footer">
                        <span class="input-hint">Enter to send · Shift+Enter for newline</span>
                        <span class="char-counter @(inputText.Length > 450 ? "near-limit" : "")">
                            @inputText.Length / 500
                        </span>
                    </div>
                </div>
                <button class="send-btn"
                        @onclick="SendMessage"
                        disabled="@(isLoading || string.IsNullOrWhiteSpace(inputText))">
                    @if (isLoading)
                    {
                        <span class="send-spinner"></span>
                    }
                    else
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                        </svg>
                    }
                </button>
            </div>

        </div><!-- end chat-content-wrapper -->
    </main>
</div>

@code {
    private Dictionary<string, List<ChatMessage>> sessions = new();
    private Dictionary<string, string> sessionToolTypes = new();
    private List<string> sessionOrder = new();
    private string? activeSessionId;
    private string currentToolType = "general";
    private string inputText = "";
    private bool isLoading;
    private string? errorMessage;
    private bool sidebarOpen;
    private bool isInputFocused;

    // Language learning state
    private bool languageLearningMode;
    private bool languageLearningLocked;
    private string nativeLanguageCode = "de";
    private string targetLanguageCode = "es";
    private const string DefaultLearningLevel = "A1";
    private const string DefaultLearningGoal = "speaking basics, verbs, sentence structure";

    private static readonly Dictionary<string, string> LanguageNames = new()
    {
        ["de"] = "German",  ["en"] = "English", ["es"] = "Spanish",
        ["fr"] = "French",  ["it"] = "Italian", ["ar"] = "Arabic",
        ["pt"] = "Portuguese"
    };

    private string nativeLanguageName => LanguageNames.GetValueOrDefault(nativeLanguageCode, nativeLanguageCode);
    private string targetLanguageName => LanguageNames.GetValueOrDefault(targetLanguageCode, targetLanguageCode);

    private List<ChatMessage> ActiveMessages =>
        activeSessionId is not null && sessions.TryGetValue(activeSessionId, out var msgs)
            ? msgs
            : new List<ChatMessage>();

    private static string? GetToolBadge(string toolType) => toolType switch
    {
        "weather"  => "🌤️",
        "language" => "🌍",
        "jokes"    => "😄",
        "summary"  => "📝",
        _          => null
    };

    private static string ToSpeechLang(string code) => code switch
    {
        "es" => "es-ES", "fr" => "fr-FR", "de" => "de-DE",
        "en" => "en-US", "it" => "it-IT", "ar" => "ar-SA",
        "pt" => "pt-PT", _ => code
    };

    private void UpdateLanguageMode()
    {
        languageLearningMode = currentToolType == "language";
        languageLearningLocked = currentToolType == "language";
    }

    private async Task SpeakTextBrowser(string text, string langCode)
    {
        if (string.IsNullOrWhiteSpace(text)) return;
        try
        {
            await JS.InvokeVoidAsync("speakText", text, ToSpeechLang(langCode));
        }
        catch { }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSessionsFromStorage();

        var toolParam = GetQueryParam(Nav.Uri, "tool");
        if (toolParam is not null)
        {
            await ActivateToolMode(toolParam);
        }
        else if (activeSessionId is not null)
        {
            currentToolType = sessionToolTypes.GetValueOrDefault(activeSessionId, "general");
            UpdateLanguageMode();
        }
    }

    private static string? GetQueryParam(string url, string key)
    {
        var query = new Uri(url).Query.TrimStart('?');
        if (string.IsNullOrEmpty(query)) return null;
        foreach (var part in query.Split('&'))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0] == key)
                return Uri.UnescapeDataString(kv[1]);
        }
        return null;
    }

    private async Task ActivateToolMode(string tool)
    {
        currentToolType = tool;
        UpdateLanguageMode();

        var id = Guid.NewGuid().ToString()[..8];
        sessions[id] = new List<ChatMessage>();
        sessionToolTypes[id] = tool;
        sessionOrder.Insert(0, id);
        activeSessionId = id;
        errorMessage = null;

        if (tool == "language")
        {
            nativeLanguageCode = "de";
            targetLanguageCode = "es";
        }

        string? welcomeText = tool switch
        {
            "weather"  => "🌤️ Weather Assistant activated! Ask me about weather in any city.\nTry: 'Wie ist das Wetter in Berlin?'",
            "summary"  => "📝 Text Summarizer ready! Paste any text and I'll summarize it.",
            "jokes"    => "😄 Joke mode on! Ask me for a joke anytime.",
            "language" => "🌍 Language Learning Mode activated!\nI will translate your messages and respond in Spanish.\nChange your target language in the panel on the left.\nTry writing: 'Hallo, wie geht es dir?'",
            _          => null
        };

        if (welcomeText is not null)
            sessions[id].Add(new ChatMessage { Text = welcomeText, IsUser = false });

        await SaveSessionsToStorage();
    }

    private async Task SaveSessionsToStorage()
    {
        var data = System.Text.Json.JsonSerializer.Serialize(sessions);
        await JS.InvokeVoidAsync("localStorage.setItem", "smartassist_sessions", data);

        var ids = System.Text.Json.JsonSerializer.Serialize(sessionOrder);
        await JS.InvokeVoidAsync("localStorage.setItem", "smartassist_session_order", ids);

        var types = System.Text.Json.JsonSerializer.Serialize(sessionToolTypes);
        await JS.InvokeVoidAsync("localStorage.setItem", "smartassist_session_types", types);

        await JS.InvokeVoidAsync("localStorage.setItem",
            "smartassist_current_session", activeSessionId ?? "");
    }

    private async Task LoadSessionsFromStorage()
    {
        try
        {
            var data = await JS.InvokeAsync<string>("localStorage.getItem", "smartassist_sessions");
            if (!string.IsNullOrEmpty(data))
                sessions = System.Text.Json.JsonSerializer
                    .Deserialize<Dictionary<string, List<ChatMessage>>>(data) ?? new();

            var orderData = await JS.InvokeAsync<string>("localStorage.getItem", "smartassist_session_order");
            if (!string.IsNullOrEmpty(orderData))
                sessionOrder = System.Text.Json.JsonSerializer
                    .Deserialize<List<string>>(orderData) ?? new();

            var typesData = await JS.InvokeAsync<string>("localStorage.getItem", "smartassist_session_types");
            if (!string.IsNullOrEmpty(typesData))
                sessionToolTypes = System.Text.Json.JsonSerializer
                    .Deserialize<Dictionary<string, string>>(typesData) ?? new();

            var savedSession = await JS.InvokeAsync<string>("localStorage.getItem", "smartassist_current_session");
            if (!string.IsNullOrEmpty(savedSession) && sessions.ContainsKey(savedSession))
                activeSessionId = savedSession;
            else if (sessionOrder.Count > 0)
                activeSessionId = sessionOrder[0];
        }
        catch { }
    }

    private async Task ClearHistory()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete all conversations?"))
            return;

        sessions.Clear();
        sessionOrder.Clear();
        sessionToolTypes.Clear();
        activeSessionId = null;
        await JS.InvokeVoidAsync("localStorage.removeItem", "smartassist_sessions");
        await JS.InvokeVoidAsync("localStorage.removeItem", "smartassist_session_order");
        await JS.InvokeVoidAsync("localStorage.removeItem", "smartassist_session_types");
        await JS.InvokeVoidAsync("localStorage.removeItem", "smartassist_current_session");
    }

    private async Task NewSession()
    {
        var id = Guid.NewGuid().ToString()[..8];
        sessions[id] = new List<ChatMessage>();
        sessionToolTypes[id] = currentToolType;
        sessionOrder.Insert(0, id);
        activeSessionId = id;
        errorMessage = null;
        await SaveSessionsToStorage();
    }

    private async Task SwitchSession(string id)
    {
        activeSessionId = id;
        errorMessage = null;
        sidebarOpen = false;
        currentToolType = sessionToolTypes.GetValueOrDefault(id, "general");
        UpdateLanguageMode();
        await SaveSessionsToStorage();
    }

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private async Task SendMessage()
    {
        var text = inputText.Trim();
        if (string.IsNullOrWhiteSpace(text) || isLoading) return;
        if (text.Length > 500)
        {
            errorMessage = "Message must not exceed 500 characters.";
            return;
        }

        if (activeSessionId is null) await NewSession();

        sessions[activeSessionId!].Add(new ChatMessage { Text = text, IsUser = true });
        inputText = "";
        isLoading = true;
        errorMessage = null;
        await SaveSessionsToStorage();

        try
        {
            var response = await AgentApi.AskAsync(
                text,
                activeSessionId,
                languageLearningMode,
                languageLearningMode ? targetLanguageName : null,
                languageLearningMode ? nativeLanguageName : null,
                languageLearningMode ? targetLanguageCode : null,
                languageLearningMode ? nativeLanguageCode : null,
                languageLearningMode ? DefaultLearningLevel : null,
                languageLearningMode ? DefaultLearningGoal : null
            );
            sessions[activeSessionId!].Add(new ChatMessage
            {
                Text = response.Reply,
                ToolUsed = response.ToolUsed,
                IsUser = false,
                LearningData = response.LearningData
            });
            await SaveSessionsToStorage();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            await ScrollToBottom();
        }
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(50);
        await JS.InvokeVoidAsync("eval",
            "var el = document.querySelector('.message-list'); if (el) el.scrollTop = el.scrollHeight;");
    }
}
