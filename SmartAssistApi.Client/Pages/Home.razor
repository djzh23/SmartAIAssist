@page "/"

<PageTitle>SmartAssist</PageTitle>

<!-- SECTION 1: Hero -->
<section class="hero-section">
    <div class="hero-inner">
        <div class="hero-icon">⚡</div>
        <h1 class="hero-title">SmartAssist</h1>
        <p class="hero-subtitle">Your AI-powered assistant with specialized tools</p>
        <div class="hero-actions">
            <a href="/chat" class="btn-hero-primary">Start Chatting</a>
            <a href="/tools" class="btn-hero-ghost">Explore Tools</a>
        </div>
    </div>
</section>

<!-- SECTION 2: How it works -->
<section class="hiw-section">
    <div class="section-inner">
        <h2 class="section-title">How it works</h2>
        <div class="hiw-grid">
            <div class="hiw-card">
                <div class="hiw-step-icon">🔧</div>
                <div class="hiw-step-num">1</div>
                <h3 class="hiw-card-title">Choose a Tool</h3>
                <p class="hiw-card-text">Browse our specialized AI tools — weather, translation, summarization and more.</p>
            </div>
            <div class="hiw-card">
                <div class="hiw-step-icon">💬</div>
                <div class="hiw-step-num">2</div>
                <h3 class="hiw-card-title">Start a Conversation</h3>
                <p class="hiw-card-text">Each tool opens a dedicated chat session, pre-configured for your task.</p>
            </div>
            <div class="hiw-card">
                <div class="hiw-step-icon">✨</div>
                <div class="hiw-step-num">3</div>
                <h3 class="hiw-card-title">Get Smart Answers</h3>
                <p class="hiw-card-text">The AI uses the right tool automatically based on your message.</p>
            </div>
        </div>
    </div>
</section>

<!-- SECTION 3: Why SmartAssist? -->
<section class="why-section">
    <div class="section-inner">
        <h2 class="section-title">Why SmartAssist?</h2>
        <div class="why-grid">
            <div class="why-card">
                <div class="why-icon">🧠</div>
                <h3 class="why-card-title">AI-Powered</h3>
                <p class="why-card-text">Powered by Anthropic Claude — one of the most advanced AI models available.</p>
            </div>
            <div class="why-card">
                <div class="why-icon">🛠️</div>
                <h3 class="why-card-title">Specialized Tools</h3>
                <p class="why-card-text">Each tool is purpose-built for its task — not a generic chatbot.</p>
            </div>
            <div class="why-card">
                <div class="why-icon">🌍</div>
                <h3 class="why-card-title">Learn While You Chat</h3>
                <p class="why-card-text">Our language learning mode helps you practice new languages naturally.</p>
            </div>
        </div>
        <div class="why-cta">
            <p class="why-cta-label">Ready to start?</p>
            <a href="/tools" class="btn-hero-primary">Explore Tools →</a>
        </div>
    </div>
</section>

<!-- SECTION 4: Footer -->
<footer class="home-footer">
    Built with .NET 9 · Blazor · Anthropic Claude API · Docker
</footer>


<style>
    /* ── Hero ────────────────────────────────────────────── */
    .hero-section {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 55vh;
        padding: var(--space-xl) var(--space-md);
        text-align: center;
    }

    .hero-inner {
        max-width: 600px;
        width: 100%;
    }

    .hero-icon {
        font-size: 3.5rem;
        line-height: 1;
        margin-bottom: var(--space-md);
    }

    .hero-title {
        font-size: 2.8rem;
        font-weight: 800;
        color: var(--color-text);
        margin-bottom: var(--space-sm);
        letter-spacing: -0.02em;
    }

    .hero-subtitle {
        font-size: 1.1rem;
        color: var(--color-text-muted);
        line-height: 1.6;
        margin-bottom: var(--space-xl);
    }

    .hero-actions {
        display: flex;
        gap: var(--space-sm);
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-hero-primary {
        display: inline-block;
        background: var(--color-primary);
        color: white;
        text-decoration: none;
        padding: 13px 32px;
        border-radius: var(--radius-sm);
        font-size: 1rem;
        font-weight: 600;
        transition: background 0.15s;
    }

    .btn-hero-primary:hover {
        background: var(--color-primary-hover);
        color: white;
        text-decoration: none;
    }

    .btn-hero-ghost {
        display: inline-block;
        background: none;
        color: var(--color-primary);
        text-decoration: none;
        padding: 12px 32px;
        border-radius: var(--radius-sm);
        font-size: 1rem;
        font-weight: 600;
        border: 1.5px solid var(--color-primary);
        transition: background 0.15s, color 0.15s;
    }

    .btn-hero-ghost:hover {
        background: var(--color-primary-light);
        color: var(--color-primary);
        text-decoration: none;
    }

    /* ── Shared section layout ───────────────────────────── */
    .section-inner {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 var(--space-xl) var(--space-xl);
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--color-text);
        margin-bottom: var(--space-lg);
        text-align: center;
    }

    /* ── How it works ────────────────────────────────────── */
    .hiw-section {
        padding: var(--space-xl) 0;
        background: var(--color-bg-secondary);
    }

    .hiw-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-md);
    }

    .hiw-card {
        background: var(--color-bg);
        border-radius: var(--radius-md);
        padding: var(--space-lg);
        text-align: center;
        position: relative;
        border: 1px solid #e5e7eb;
    }

    .hiw-step-icon {
        font-size: 2rem;
        margin-bottom: var(--space-sm);
        display: block;
        background: var(--color-primary-light);
        width: 56px;
        height: 56px;
        line-height: 56px;
        border-radius: 50%;
        margin: 0 auto var(--space-sm);
    }

    .hiw-step-num {
        position: absolute;
        top: var(--space-md);
        right: var(--space-md);
        width: 22px;
        height: 22px;
        background: var(--color-primary);
        color: white;
        border-radius: 50%;
        font-size: 11px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hiw-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-text);
        margin: var(--space-sm) 0 var(--space-xs);
    }

    .hiw-card-text {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        line-height: 1.5;
        margin: 0;
    }

    /* ── Why SmartAssist ────────────────────────────────── */
    .why-section {
        padding: var(--space-xl) 0;
    }

    .why-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-md);
        margin-bottom: var(--space-xl);
    }

    .why-card {
        background: var(--color-bg);
        border: 1px solid #e5e7eb;
        border-radius: var(--radius-md);
        padding: var(--space-lg);
        text-align: center;
    }

    .why-icon {
        font-size: 2rem;
        margin-bottom: var(--space-sm);
    }

    .why-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-text);
        margin-bottom: var(--space-xs);
    }

    .why-card-text {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        line-height: 1.5;
        margin: 0;
    }

    .why-cta {
        text-align: center;
        padding-top: var(--space-md);
    }

    .why-cta-label {
        font-size: 1rem;
        color: var(--color-text-muted);
        margin-bottom: var(--space-md);
    }

    /* ── Footer ──────────────────────────────────────────── */
    .home-footer {
        text-align: center;
        padding: var(--space-lg) var(--space-md);
        color: var(--color-text-muted);
        font-size: 0.78rem;
        border-top: 1px solid #e5e7eb;
    }

    /* ── Responsive ──────────────────────────────────────── */
    @@media (max-width: 768px) {
        .hero-title {
            font-size: 2rem;
        }

        .hiw-grid {
            grid-template-columns: 1fr;
        }

        .why-grid {
            grid-template-columns: 1fr;
        }

        .section-inner {
            padding: 0 var(--space-md) var(--space-lg);
        }
    }
</style>
