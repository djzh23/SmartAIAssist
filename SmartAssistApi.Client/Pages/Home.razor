@page "/"

<PageTitle>SmartAssist</PageTitle>

<div class="home-container">
    <div class="home-card">
        <div class="home-logo">⚡</div>
        <h1 class="home-title">SmartAssist</h1>
        <p class="home-description">
            Your AI-powered assistant with real tools.<br />
            Ask questions, get summaries, fetch live data — all in one chat.
        </p>
        <a href="/chat" class="btn-go-chat">Start Chatting</a>
    </div>
</div>

<style>
    .home-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100%;
        padding: var(--space-xl);
        box-sizing: border-box;
    }

    .home-card {
        text-align: center;
        max-width: 440px;
        padding: var(--space-xl);
    }

    .home-logo {
        font-size: 3.5rem;
        margin-bottom: var(--space-md);
        line-height: 1;
    }

    .home-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--color-text);
        margin-bottom: var(--space-sm);
    }

    .home-description {
        color: var(--color-text-muted);
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: var(--space-xl);
    }

    .btn-go-chat {
        display: inline-block;
        background: var(--color-primary);
        color: white;
        text-decoration: none;
        padding: 12px 32px;
        border-radius: var(--radius-sm);
        font-size: 1rem;
        font-weight: 500;
        transition: background 0.15s;
    }

    .btn-go-chat:hover {
        background: var(--color-primary-hover);
        color: white;
        text-decoration: none;
    }
</style>
