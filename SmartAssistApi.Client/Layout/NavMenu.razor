@inject NavigationManager Nav
@implements IDisposable

<div class="nav-brand" @onclick="CloseNav">
    <span class="brand-logo">⚡</span>
    <span class="brand-name">SmartAssist</span>
</div>

<div class="nav-section-separator"></div>

<nav class="nav-links">
    <div class="nav-section-label">Main</div>
    <NavLink class="nav-link-item" href="" Match="NavLinkMatch.All" @onclick="CloseNav">
        <span class="nav-icon">🏠</span>
        <span>Home</span>
    </NavLink>
    <NavLink class="nav-link-item" href="tools" @onclick="CloseNav">
        <span class="nav-icon">🔧</span>
        <span>Tools</span>
    </NavLink>

    <div class="nav-section-label">My Chats</div>
    <a class="nav-link-item @IsActiveGeneral()" @onclick='() => NavigateToChat("")' @onclick:preventDefault href="chat">
        <span class="nav-icon">💬</span>
        <span>General Chat</span>
    </a>
    <a class="nav-link-item @IsActiveTool("weather")" @onclick='() => NavigateToChat("weather")' @onclick:preventDefault href="chat?tool=weather">
        <span class="nav-icon">🌤️</span>
        <span>Weather</span>
    </a>
    <a class="nav-link-item @IsActiveTool("jobanalyzer")" @onclick='() => NavigateToChat("jobanalyzer")' @onclick:preventDefault href="chat?tool=jobanalyzer">
        <span class="nav-icon">💼</span>
        <span>Job Analyzer</span>
    </a>
    <a class="nav-link-item @IsActiveTool("jokes")" @onclick='() => NavigateToChat("jokes")' @onclick:preventDefault href="chat?tool=jokes">
        <span class="nav-icon">😄</span>
        <span>Jokes</span>
    </a>
    <a class="nav-link-item @IsActiveTool("language")" @onclick='() => NavigateToChat("language")' @onclick:preventDefault href="chat?tool=language">
        <span class="nav-icon">🌍</span>
        <span>Language</span>
    </a>
    <a class="nav-link-item @IsActiveTool("programming")" @onclick='() => NavigateToChat("programming")' @onclick:preventDefault href="chat?tool=programming">
        <span class="nav-icon">💻</span>
        <span>Programming</span>
    </a>
</nav>

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void CloseNav() => OnClose.InvokeAsync();

    private void NavigateToChat(string tool)
    {
        var url = string.IsNullOrEmpty(tool) ? "chat" : $"chat?tool={tool}";
        Nav.NavigateTo(url, forceLoad: false);
        OnClose.InvokeAsync();
    }

    private string IsActiveTool(string tool)
    {
        var current = GetQueryParam(Nav.Uri, "tool");
        return current == tool ? "active" : "";
    }

    private string IsActiveGeneral()
    {
        var uri = new Uri(Nav.Uri);
        var isChat = uri.AbsolutePath.EndsWith("/chat", StringComparison.OrdinalIgnoreCase)
                  || uri.AbsolutePath.EndsWith("/chat/", StringComparison.OrdinalIgnoreCase);
        var hasTool = uri.Query.Contains("tool=");
        return isChat && !hasTool ? "active" : "";
    }

    private static string? GetQueryParam(string url, string key)
    {
        var query = new Uri(url).Query.TrimStart('?');
        if (string.IsNullOrEmpty(query)) return null;
        foreach (var part in query.Split('&'))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0] == key)
                return Uri.UnescapeDataString(kv[1]);
        }
        return null;
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}